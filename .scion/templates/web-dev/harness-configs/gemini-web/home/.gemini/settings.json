{
  "yolo": true,
  "security": {
    "auth": {
      "selectedType": "gemini-api-key"
    },
    "folderTrust": {
      "enabled": false
    }
  },
  "context": {
    "fileName": ["CLAUDE.md","AGENTS.md", "GEMINI.md"]
  },
  "model": {
    "skipNextSpeakerCheck": true,
    "name": "gemini-3-flash-preview"
  },
  "telemetry": {
    "enabled": false
  },
  "general": {
    "disableAutoUpdate": true,
    "disableUpdateNag": true,
    "previewFeatures": true
  },
  "ui": {
    "accessibility": {
      "disableLoadingPhrases": true
    },
    "hideFooter": true,
    "hideWindowTitle": true
  },
  "tools": {
    "enableMessageBusIntegration": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "scion-status",
            "type": "command",
            "command": "sciontool hook --dialect=gemini"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "scion-status",
            "type": "command",
            "command": "sciontool hook --dialect=gemini"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "scion-status",
            "type": "command",
            "command": "sciontool hook --dialect=gemini"
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "scion-status",
            "type": "command",
            "command": "sciontool hook --dialect=gemini"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "scion-status",
            "type": "command",
            "command": "sciontool hook --dialect=gemini"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "scion-status",
            "type": "command",
            "command": "sciontool hook --dialect=gemini"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "ToolPermission",
        "hooks": [
          {
            "name": "scion-status",
            "type": "command",
            "command": "sciontool hook --dialect=gemini"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "chrome-devtools-mcp",
      "args": ["--headless", "--browser-url", "http://localhost:9222"],
      "env": {}
    }
  }
}
